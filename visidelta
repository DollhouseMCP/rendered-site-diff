#!/usr/bin/env bash

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

BASE_REF="${VISIDELTA_BASE_REF:-origin/main}"
OUT_DIR="${VISIDELTA_OUT_DIR:-/tmp/visidelta}"
MODE="${VISIDELTA_MODE:-serve}"
TARGET_REPO="${1:-$PWD}"

if [[ "${1:-}" == "--help" || "${1:-}" == "-h" ]]; then
  cat <<'HELP'
VisiDelta one-command launcher

Usage:
  visidelta [TARGET_REPO]

Environment overrides:
  VISIDELTA_BASE_REF  (default: origin/main)
  VISIDELTA_OUT_DIR   (default: /tmp/visidelta)
  VISIDELTA_MODE      (default: serve)
  VISIDELTA_PORT      (default: 4310)

Examples:
  visidelta
  VISIDELTA_BASE_REF=HEAD~1 visidelta /path/to/repo
HELP
  exit 0
fi

exec "$SCRIPT_DIR/scripts/visidelta.sh" "$BASE_REF" "$OUT_DIR" "$MODE" "$TARGET_REPO"
